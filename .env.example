# Copy to .env and fill in. Bun auto-loads .env (no dotenv needed). .env is gitignored.
ANTHROPIC_API_KEY=        # Claude Agent SDK — agent loop, daily session
ELEVENLABS_API_KEY=       # TTS — spoken prompts + seed audio
OPENAI_API_KEY=           # STT — gpt-4o-transcribe for spoken answers
ELEVENLABS_VOICE_ID=      # optional — a Mexican Spanish voice for the Spanish pack
