{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "types": ["bun", "react", "react-dom"]
  },
  "comment": "server.ts is excluded — it imports ../src (the Bun engine); Bun runs it directly. The FE (src) carries no engine types.",
  "include": ["src", "vite.config.ts"]
}
